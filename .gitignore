```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Python artifacts (if any Python in project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Temporary files
*.tmp
*.temp

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Test cache
.pytest_cache/
.mypy_cache/

# Distribution / packaging
*.tar.gz
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt

# Local development settings
.settings/
*.local
```
