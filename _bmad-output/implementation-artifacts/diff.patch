++} from "./coach.js";
++import { captureUserInput, cleanSttTranscript } from "./speech.js";
++import {
++  SessionContext,
++  ConversationTurn,
++  HarnessTestResult,
++  SessionPhase,
++} from "./types.js";
++
++// ─── Colours ──────────────────────────────────────────────────────────────────
++
++const C = {
++  reset: "\x1b[0m",
++  bold: "\x1b[1m",
