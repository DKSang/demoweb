++++++++++function addToHistory(
++++++++++  ctx: SessionContext,
++++++++++  role: "coach" | "learner",
++++++++++  text: string,
++++++++++  phase: SessionPhase
++++++++++) {
++++++++++  ctx.history.push({ role, text, timestamp: new Date(), phase });
