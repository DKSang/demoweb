++++++++++        youtubeUrl: "",
++++++++++        videoId: "test",
++++++++++        transcript: [],
++++++++++        rawTranscript: context,
++++++++++        fetchedAt: new Date(),
++++++++++      };
++++++++++      vocab = {
++++++++++        topic: "general conversation",
++++++++++        keyPhrases: [],
++++++++++        vocab: [],
++++++++++      };
++++++++++    }
++++++++++
++++++++++    const ctx: SessionContext = {
++++++++++      lesson,
++++++++++      vocab,
++++++++++      phase: "practice",
++++++++++      history: [],
